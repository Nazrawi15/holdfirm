{
  "name": "@yo-protocol/core",
  "version": "1.0.9",
  "description": "TypeScript SDK for interacting with the yield protocol",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "big.js": "^7.0.1",
    "viem": "2.44.2"
  },
  "devDependencies": {
    "@types/big.js": "^6.2.2",
    "esbuild": "0.24.2",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "keywords": [
    "yield",
    "defi",
    "viem",
    "ethereum",
    "erc4626",
    "vault"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yo-xyz/yo-kit.git"
  },
  "author": "yo-protocol",
  "bugs": {
    "url": "https://github.com/yo-xyz/yo-kit/issues"
  },
  "homepage": "https://github.com/yo-xyz/yo-kit#readme",
  "scripts": {
    "build": "node build.js && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "node build.js --watch",
    "clean": "rm -rf dist",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__/utils src/__tests__/constants src/__tests__/api/client",
    "test:api": "vitest run src/__tests__/api",
    "test:e2e": "vitest run src/__tests__/reads src/__tests__/actions src/__tests__/client.test.ts",
    "test:watch": "vitest"
  }
}