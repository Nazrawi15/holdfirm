{
  "name": "@yo-protocol/react",
  "version": "1.0.6",
  "description": "React components and hooks for the yield protocol",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "dependencies": {
    "clsx": "2.1.1",
    "@yo-protocol/core": "1.0.9"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "viem": ">=2.0.0",
    "wagmi": ">=2.0.0"
  },
  "devDependencies": {
    "@types/react": "18.3.27",
    "@types/react-dom": "18.3.7",
    "esbuild": "0.24.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "5.9.3"
  },
  "keywords": [
    "yield",
    "react",
    "defi",
    "wagmi",
    "viem",
    "erc4626"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yo-xyz/yo-kit"
  },
  "scripts": {
    "build": "node build.js && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "node build.js --watch",
    "clean": "rm -rf dist",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  }
}